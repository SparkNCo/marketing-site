---
const POSTHOG_KEY = import.meta.env.PUBLIC_POSTHOG_INIT;
---

<script is:inline define:vars={{ POSTHOG_KEY }}>
  !(function (t, e) {
    var o, n, p, r;
    e.__SV ||
      (window.posthog && window.posthog.__loaded) ||
      ((window.posthog = e),
      (e._i = []),
      (e.init = function (i, s, a) {
        function g(t, e) {
          var o = e.split(".");
          if (o.length === 2) {
            t = t[o[0]];
            e = o[1];
          }
          t[e] = function () {
            t.push([e].concat(Array.prototype.slice.call(arguments, 0)));
          };
        }

        p = t.createElement("script");
        p.type = "text/javascript";
        p.async = true;
        p.crossOrigin = "anonymous";
        p.src =
          s.api_host.replace(".i.posthog.com", "-assets.i.posthog.com") +
          "/static/array.js";

        r = t.getElementsByTagName("script")[0];
        r.parentNode.insertBefore(p, r);

        var u = e;
        a ? (u = e[a] = []) : (a = "posthog");

        const methods =
          "capture identify opt_in_capturing opt_out_capturing has_opted_in_capturing".split(
            " "
          );

        for (let i = 0; i < methods.length; i++) {
          g(u, methods[i]);
        }

        e._i.push([i, s, a]);
      }),
      (e.__SV = 1));
  })(document, window.posthog || []);

  posthog.init(POSTHOG_KEY, {
    api_host: "https://us.i.posthog.com",
    person_profiles: "identified_only",
    opt_out_capturing_by_default: true,
  });
</script>

<!-- ✅ Consent Restore -->
<script is:inline>
  function applyPosthogConsent() {
    if (!window.posthog) {
      setTimeout(applyPosthogConsent, 50);
      return;
    }

    const consent = localStorage.getItem("cookie_consent");

    if (consent === "accepted") {
      window.posthog.opt_in_capturing();
      window.posthog.capture("$pageview");
    }

    if (consent === "rejected") {
      window.posthog.opt_out_capturing();
    }
  }

  applyPosthogConsent();
</script>
---
import Posthog from "../posthog.astro";
import CookieBanner from "../utils/CookieBanner";

const location = Astro.url.pathname;
---

<html lang="en">
  <head>
    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <Posthog />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Nunito+Sans:ital,opsz,wght@0,6..12,200..1000;1,6..12,200..1000&family=Space+Grotesk:wght@300..700&display=swap"
      rel="stylesheet"
    />

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>

  <body class="bg-background">
    <slot />
    <CookieBanner client:load />
  </body><!-- foreground -->
  <style is:global>
    :root {
      --font-title: "Space Grotesk";
      --font-body: "Nunito Sans";
      --background: #111111;
      --foreground: #f7f4f0;
      --primary: #f78035;
      --secondary: #f7f4f0;
      --card: #f7f4f0;
      --donut: #b5b5b5;
      .hide-scrollbar {
        scrollbar-width: none; /* Firefox */
      }

      .hide-scrollbar::-webkit-scrollbar {
        display: none; /* Chrome/Safari */
      }
    }

    body {
      margin: 0;
      font-family: var(--font-body);
      background-color: var(--background);
    }

    .font-title {
      font-family: var(--font-title);
    }

    .font-body {
      font-family: var(--font-body);
    }

    /* ✅ KEYFRAMES MUST BE TOP LEVEL */
    @keyframes scroll-right {
      from {
        transform: translateX(0);
      }
      to {
        transform: translateX(-50%);
      }
    }

    @keyframes square-color {
      0% {
        background-color: var(--color-1);
      }
      50% {
        background-color: var(--color-2);
      }
      100% {
        background-color: var(--color-1);
      }
    }

    @keyframes scroll-left {
      from {
        transform: translateX(-50%);
      }
      to {
        transform: translateX(0);
      }
    }

    /* ✅ SHARED STYLES */
    .animate-scroll-right,
    .animate-scroll-left {
      display: flex;
      gap: 2rem;
      width: max-content;
    }

    /* ✅ INDIVIDUAL ANIMATIONS */
    .animate-scroll-right {
      animation: scroll-right 90s linear infinite;
    }

    .animate-scroll-left {
      animation: scroll-left 90s linear infinite;
    }

    @keyframes loading-dot {
      0% {
        transform: translateX(120%) scale(0.9);
        opacity: 0;
      }

      20% {
        opacity: 1;
      }

      50% {
        transform: translateX(0%) scale(1.05);
        opacity: 1;
      }

      80% {
        opacity: 1;
      }

      100% {
        transform: translateX(-120%) scale(0.9);
        opacity: 0;
      }
    }

    .animate-loading-dot {
      animation: loading-dot 2.2s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    }

    .rightColumn {
      position: relative;
      width: 600px;
      border: 4px solid red;
    }

    .rightSticky {
      position: sticky;
      top: 192px;
      border: 4px solid white;
    }

    .title {
      font-size: 24px;
      font-weight: bold;
      margin-bottom: 16px;
    }

    .content {
      min-height: 12rem;
    }

    .cookie-banner {
      position: fixed;
      bottom: 24px;
      left: 24px;

      max-width: 420px;
      padding: 18px 20px;

      background: var(--background);
      color: var(--foreground);
      border: 3px solid var(--primary);
      border-radius: 12px;

      font-family: var(--font-body);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);

      z-index: 99999;

      opacity: 0;
      transform: translateX(-40px);
      visibility: hidden;

      transition:
        opacity 0.45s ease,
        transform 0.45s cubic-bezier(0.22, 1, 0.36, 1),
        visibility 0.45s;
    }

    .cookie-banner.show {
      opacity: 1;
      transform: translateX(0);
      visibility: visible;
    }

    .cookie-banner p {
      margin: 0 0 12px 0;
      line-height: 1.4;
    }

    .cookie-banner .actions {
      display: flex;
      gap: 10px;
      justify-content: flex-end;
    }

    .cookie-banner button {
      cursor: pointer;
      border-radius: 6px;
      padding: 8px 14px;
      font-weight: 500;
      border: none;
      transition: all 0.2s ease;
    }

    .cookie-banner button.reject {
      background: transparent;
      color: var(--foreground);
      border: 1px solid var(--secondary);
    }

    .cookie-banner button.reject:hover {
      background: rgba(255, 255, 255, 0.08);
    }

    .cookie-banner button.accept {
      background: var(--primary);
      color: #111;
    }

    .cookie-banner button.accept:hover {
      filter: brightness(1.1);
    }
  </style>
</html>

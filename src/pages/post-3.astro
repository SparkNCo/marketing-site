---
import PostsLayout from "../components/layouts/PostsLayout.astro";
import { PostShell5 } from "../components/posts/PostShell";

const user = Astro.locals.user;
const location = Astro.url.pathname;
const blog = Astro.url.searchParams.get("blog");

const squaresConfig = [
  {
    x: "0px",
    y: "990px", // 1080 - 90
    width: "450px",
    height: "180px",
    color: "#111111",
  },
  {
    x: "90px",
    y: "900px", // 990 - 90
    width: "180px",
    height: "90px",
    color: "#111111",
  },
  {
    x: "810px",
    y: "990px", // 1080 - 90
    width: "270px",
    height: "180px",
    color: "#111111",
  },
  {
    x: "810px",
    y: "900px", // 990 - 90
    width: "90px",
    height: "90px",
    color: "#111111",
  },
];
---

<div>
  <PostsLayout>
    <>
      <PostShell5
        squaresConfig={squaresConfig}
        blog={blog}
        layoutType="centered"
        for
        PostPageCentered
        layout
      />
    </>
  </PostsLayout>
</div>

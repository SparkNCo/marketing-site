---
import { QueryClientProvider } from "@tanstack/react-query";
import PostsLayout from "../components/layouts/PostsLayout.astro";
import { PostShell5 } from "../components/posts/PostShell";
import { queryClient } from "../lib/tanStack";

const user = Astro.locals.user;
const location = Astro.url.pathname;
const blog = Astro.url.searchParams.get("blog");

const squaresConfig = [
  {
    x: "0px",
    y: "990px", // 1080 - 90
    width: "450px",
    height: "180px",
    color: "#111111",
  },
  {
    x: "90px",
    y: "900px", // 990 - 90
    width: "180px",
    height: "90px",
    color: "#111111",
  },
  {
    x: "810px",
    y: "990px", // 1080 - 90
    width: "270px",
    height: "180px",
    color: "#111111",
  },
  {
    x: "810px",
    y: "900px", // 990 - 90
    width: "90px",
    height: "90px",
    color: "#111111",
  },
];
---

<div>
  <PostsLayout>
    <PostShell5
      client:load
      squaresConfig={squaresConfig}
      blog={blog}
      layoutType="page3"
      for
      PostPage2
      layout
    />
  </PostsLayout>
</div>

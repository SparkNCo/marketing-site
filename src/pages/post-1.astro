---
import PostsLayout from "../components/layouts/PostsLayout.astro";
import { Post1Client } from "../components/posts/Post1Client";

const blog = Astro.url.searchParams.get("blog");
const edit = Astro.url.searchParams.get("edit");
const squaresConfig = [
  {
    // long bottom bar
    x: "90px",
    y: "990px",
    width: "990px",
    height: "90px",
    color: "#111111",
  },
  {
    // 2nd line bottom bar left
    x: "180px",
    y: "900px",
    width: "180px",
    height: "90px",
    color: "#111111",
  },
  {
    // 4th line left
    x: "90px",
    y: "720px",
    width: "90px",
    height: "90px",
    color: "#111111",
  },
  {
    // 2nd line bottom bar middle
    x: "450px",
    y: "900px",
    width: "720px",
    height: "90px",
    color: "#111111",
  },

  {
    // 3rd line bottom bar middle
    x: "540px",
    y: "810px",
    width: "180px",
    height: "90px",
    color: "#111111",
  },
  {
    // 4rd line bottom bar middle
    x: "540px",
    y: "720px",
    width: "90px",
    height: "90px",
    color: "#111111",
  },

  {
    // Big Sqaure on the right
    x: "900px",
    y: "720px",
    width: "180px",
    height: "180px",
    color: "#111111",
  },
  {
    // Big Sqaure floating right
    x: "720px",
    y: "540px",
    width: "180px",
    height: "180px",
    color: "#111111",
  },
  {
    // Small Sqaure floating right
    x: "810px",
    y: "450px",
    width: "90px",
    height: "90px",
    color: "#111111",
  },
];
---

<PostsLayout>
  <Post1Client
    client:load
    squaresConfig={squaresConfig}
    blog={blog}
    edit={edit}
  /></PostsLayout
>

---
import PostsLayout from "../components/layouts/PostsLayout.astro";
import { PostShell1 } from "../components/posts/PostShell";

const user = Astro.locals.user;
const location = Astro.url.pathname;
const blog = Astro.url.searchParams.get("blog");
const squaresConfig = [
  {
    // long bottom bar
    x: "90px",
    y: "990px",
    width: "990px",
    height: "90px",
    color: "#111111",
  },
  {
    // 2nd line bottom bar left
    x: "180px",
    y: "900px",
    width: "180px",
    height: "90px",
    color: "#111111",
  },
  {
    // 4th line left
    x: "90px",
    y: "720px",
    width: "90px",
    height: "90px",
    color: "#111111",
  },
  {
    // 2nd line bottom bar middle
    x: "450px",
    y: "900px",
    width: "720px",
    height: "90px",
    color: "#111111",
  },

  {
    // 3rd line bottom bar middle
    x: "540px",
    y: "810px",
    width: "180px",
    height: "90px",
    color: "#111111",
  },
  {
    // 4rd line bottom bar middle
    x: "540px",
    y: "720px",
    width: "90px",
    height: "90px",
    color: "#111111",
  },

  {
    // Big Sqaure on the right
    x: "900px",
    y: "720px",
    width: "180px",
    height: "180px",
    color: "#111111",
  },
  {
    // Big Sqaure floating right
    x: "720px",
    y: "540px",
    width: "180px",
    height: "180px",
    color: "#111111",
  },
  {
    // Small Sqaure floating right
    x: "810px",
    y: "450px",
    width: "90px",
    height: "90px",
    color: "#111111",
  },
];
---

<PostsLayout>
  <PostShell1
    location={location}
    user={user}
    blog={blog}
    client:load
    squaresConfig={squaresConfig}
  />
</PostsLayout>
